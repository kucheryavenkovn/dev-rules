<KnowledgeGraph>
  <Project NAME="GRACE-DOCX Generator" VERSION="0.2.0">
    <keywords>1C, BSL, Word, docx, GRACE, markdown, documentation, standards, code-style, CI/CD, Git, RabbitMQ, Docusaurus, XML, semantic-markup</keywords>
    <annotation>Генератор Word-документа «Стандарты разработки» с GRACE-DOCX v3 семантической разметкой.</annotation>

    <M-CONFIG NAME="Config" TYPE="UTILITY" STATUS="planned">
      <purpose>Конфигурация генератора: пути, версия документа, порядок глав, настройки стилей</purpose>
      <path>generate-grace-docx.py (секция CONFIGURATION)</path>
      <depends>none</depends>
      <verification-ref>V-M-CONFIG</verification-ref>
      <annotations>
        <fn-setup_styles PURPOSE="Настроить стили документа Word (заголовки, код, обычный текст)"/>
        <fn-derive_module_id PURPOSE="Генерация уникального Module ID из заголовка"/>
        <fn-classify_module_type PURPOSE="Определить тип модуля GRACE по HTML-содержимому"/>
      </annotations>
    </M-CONFIG>

    <M-PARSER NAME="MarkdownParser" TYPE="UTILITY" STATUS="planned">
      <purpose>Чтение и парсинг Markdown-файлов из docs/: frontmatter, заголовки, контент</purpose>
      <path>generate-grace-docx.py (секция PARSING)</path>
      <depends>M-CONFIG</depends>
      <verification-ref>V-M-PARSER</verification-ref>
      <annotations>
        <fn-read_md PURPOSE="Прочитать .md файл и вернуть заголовок + очищенный текст"/>
        <fn-strip_frontmatter PURPOSE="Удалить YAML frontmatter из markdown"/>
        <fn-get_frontmatter_title PURPOSE="Извлечь заголовок из frontmatter"/>
        <fn-md_to_html PURPOSE="Конвертировать Markdown → HTML через markdown-библиотеку"/>
      </annotations>
    </M-PARSER>

    <M-STRUCTURE NAME="ChapterStructure" TYPE="CORE_LOGIC" STATUS="planned">
      <purpose>Определение иерархии глав репозитория: порядок, вложенность, маппинг на файлы</purpose>
      <path>generate-grace-docx.py (OrderedDict CHAPTERS)</path>
      <depends>M-CONFIG</depends>
      <verification-ref>V-M-STRUCTURE</verification-ref>
      <annotations>
        <fn-collect_chapters PURPOSE="Собрать плоский список глав из иерархического словаря"/>
        <type-ChapterInfo PURPOSE="Структура данных главы: heading, source, depth, parent_id"/>
      </annotations>
    </M-STRUCTURE>

    <M-RENDERER NAME="DocxRenderer" TYPE="CORE_LOGIC" STATUS="planned">
      <purpose>Рендеринг HTML-контента в параграфы, таблицы, списки и код docx</purpose>
      <path>generate-grace-docx.py (секция RENDERING)</path>
      <depends>M-PARSER, M-CONFIG</depends>
      <verification-ref>V-M-RENDERER</verification-ref>
      <annotations>
        <fn-render_html_to_doc PURPOSE="Главная функция рендеринга HTML → docx элементы"/>
        <fn-render_paragraph PURPOSE="Рендеринг HTML параграфа с inline-стилями (bold, italic, code, links)"/>
        <fn-render_table PURPOSE="Рендеринг HTML таблицы в Word таблицу"/>
        <fn-render_list PURPOSE="Рендеринг HTML списка (ordered/unordered) с вложенностью"/>
      </annotations>
    </M-RENDERER>

    <M-DOCXBUILDER NAME="DocumentBuilder" TYPE="ENTRY_POINT" STATUS="planned">
      <purpose>Сборка полного документа: титульная страница, оглавление, главы с закладками</purpose>
      <path>generate-grace-docx.py (секция main)</path>
      <depends>M-RENDERER, M-STRUCTURE, M-GRACE</depends>
      <verification-ref>V-M-DOCXBUILDER</verification-ref>
      <annotations>
        <fn-main PURPOSE="Точка входа: создание документа, итерация по главам, сохранение"/>
      </annotations>
    </M-DOCXBUILDER>

    <M-GRACE NAME="GraceInjector" TYPE="CORE_LOGIC" STATUS="planned">
      <purpose>Инъекция 5 GRACE XML-частей и парных закладок в .docx архив</purpose>
      <path>generate-grace-docx.py (секция GRACE XML)</path>
      <depends>M-STRUCTURE</depends>
      <verification-ref>V-M-GRACE</verification-ref>
      <annotations>
        <fn-make_grace_manifest PURPOSE="Генерация grace-manifest.xml — точки входа GRACE"/>
        <fn-make_grace_instructions PURPOSE="Генерация grace-instructions.xml — правила поведения агентов"/>
        <fn-make_grace_graph PURPOSE="Генерация grace-graph.xml — карта модулей с элементами"/>
        <fn-make_grace_contracts PURPOSE="Генерация grace-contracts.xml — контракты редактирования"/>
        <fn-make_grace_verification PURPOSE="Генерация grace-verification.xml — инварианты и проверки"/>
        <fn-inject_bookmark PURPOSE="Вставка пары bookmarkStart/bookmarkEnd в document.xml"/>
      </annotations>
    </M-GRACE>

    <M-VALIDATOR NAME="OutputValidator" TYPE="UTILITY" STATUS="planned">
      <purpose>Проверка целостности сгенерированного .docx: валидация XML, баланс закладок, Content_Types</purpose>
      <path>generate-grace-docx.py (секция VALIDATION — планируется)</path>
      <depends>M-GRACE</depends>
      <verification-ref>V-M-VALIDATOR</verification-ref>
      <annotations>
        <fn-validate_grace_xml PURPOSE="Проверить, что все grace-*.xml парсятся как валидный XML"/>
        <fn-validate_bookmarks PURPOSE="Проверить парность и уникальность GRACE-закладок"/>
        <fn-validate_content_types PURPOSE="Проверить регистрацию GRACE-частей в Content_Types"/>
      </annotations>
    </M-VALIDATOR>

