<KnowledgeGraph>
  <Project NAME="GRACE-DOCX Generator" VERSION="0.3.0">
    <keywords>1C, BSL, Word, docx, GRACE, markdown, documentation, standards, code-style, CI/CD, Git, RabbitMQ, Docusaurus, XML, semantic-markup</keywords>
    <annotation>Генератор Word-документа «Стандарты разработки» с GRACE-DOCX v3 семантической разметкой. Порядок глав определяется Docusaurus sidebar auto-generation.</annotation>

    <M-TYPES NAME="Types" TYPE="UTILITY" STATUS="planned">
      <purpose>Общие frozen dataclass-типы для всех модулей: ChapterInfo, ModuleInfo, GraceModule</purpose>
      <path>src/types.py</path>
      <depends>none</depends>
      <verification-ref>V-M-TYPES</verification-ref>
      <annotations>
        <type-ChapterInfo PURPOSE="Структура главы: heading, source, depth, position, parent_heading, is_container, rel_path"/>
        <type-ModuleInfo PURPOSE="Структура модуля: id, heading, type, para_start, para_end, elements, parent"/>
        <type-GraceModule PURPOSE="Структура grace-модуля для XML-инъекции"/>
      </annotations>
    </M-TYPES>

    <M-CONFIG NAME="Config" TYPE="UTILITY" STATUS="planned">
      <purpose>Конфигурация генератора: пути, версия документа, стили Word, маппинг заголовков → Module ID</purpose>
      <path>src/config.py</path>
      <depends>M-TYPES</depends>
      <verification-ref>V-M-CONFIG</verification-ref>
      <annotations>
        <fn-setup_styles PURPOSE="Настроить стили документа Word"/>
        <fn-derive_module_id PURPOSE="Генерация уникального Module ID из заголовка"/>
        <fn-classify_module_type PURPOSE="Определить тип модуля GRACE по HTML-содержимому"/>
      </annotations>
    </M-CONFIG>

    <M-PARSER NAME="MarkdownParser" TYPE="UTILITY" STATUS="planned">
      <purpose>Чтение и парсинг Markdown-файлов из docs/: frontmatter, заголовки, контент</purpose>
      <path>src/parser.py</path>
      <depends>M-CONFIG</depends>
      <verification-ref>V-M-PARSER</verification-ref>
      <annotations>
        <fn-read_md PURPOSE="Прочитать .md файл и вернуть заголовок + очищенный текст"/>
        <fn-strip_frontmatter PURPOSE="Удалить YAML frontmatter из markdown"/>
        <fn-get_frontmatter_title PURPOSE="Извлечь заголовок из frontmatter"/>
        <fn-md_to_html PURPOSE="Конвертировать Markdown → HTML"/>
      </annotations>
    </M-PARSER>

    <M-DISCOVERY NAME="DocDiscovery" TYPE="CORE_LOGIC" STATUS="planned">
      <purpose>Динамическое обнаружение структуры документации из файловой системы Docusaurus</purpose>
      <path>src/discovery.py</path>
      <depends>M-CONFIG, M-TYPES</depends>
      <verification-ref>V-M-DISCOVERY</verification-ref>
      <annotations>
        <fn-scan_docs_directory PURPOSE="Сканировать docs/ и построить иерархию ChapterNode"/>
        <fn-flatten_chapters PURPOSE="Развернуть дерево ChapterNode в плоский список"/>
        <fn-read_category_json PURPOSE="Прочитать _category_.json из каталога"/>
        <fn-read_md_frontmatter_position PURPOSE="Извлечь sidebar_position и title из .md"/>
        <type-ChapterNode PURPOSE="Dataclass узла главы"/>
      </annotations>
    </M-DISCOVERY>

    <M-SIDEBAR NAME="SidebarOrder" TYPE="CORE_LOGIC" STATUS="planned">
      <purpose>Построение авторитетного порядка глав, идентичного Docusaurus sidebar auto-generation</purpose>
      <path>src/sidebar_order.py</path>
      <depends>M-CONFIG, M-DISCOVERY, M-TYPES</depends>
      <verification-ref>V-M-SIDEBAR</verification-ref>
      <annotations>
        <fn-build_chapter_order PURPOSE="Построить упорядоченный список глав через sidebar_position"/>
      </annotations>
    </M-SIDEBAR>

    <M-GRAPHSYNC NAME="GraphSync" TYPE="CORE_LOGIC" STATUS="planned">
      <purpose>Чтение/запись knowledge-graph.xml DocChapters, roundtrip sync с файловой системой</purpose>
      <path>src/graph_sync.py</path>
      <depends>M-CONFIG, M-DISCOVERY, M-SIDEBAR, M-TYPES</depends>
      <verification-ref>V-M-GRAPHSYNC</verification-ref>
      <annotations>
        <fn-sync_graph_from_fs PURPOSE="Синхронизировать knowledge-graph.xml с файловой системой"/>
        <fn-chapters_from_graph PURPOSE="Прочитать DocChapters из knowledge-graph.xml"/>
        <fn-build_grace_graph_xml PURPOSE="Построить grace-graph.xml для инъекции"/>
      </annotations>
    </M-GRAPHSYNC>

    <M-RENDERER NAME="DocxRenderer" TYPE="CORE_LOGIC" STATUS="planned">
      <purpose>Рендеринг HTML-контента в параграфы, таблицы, списки и код docx</purpose>
      <path>src/renderer.py</path>
      <depends>M-CONFIG, M-TYPES</depends>
      <verification-ref>V-M-RENDERER</verification-ref>
      <annotations>
        <fn-render_html_to_doc PURPOSE="Главная функция рендеринга HTML → docx"/>
        <fn-render_paragraph PURPOSE="Рендеринг HTML параграфа с inline-стилями"/>
        <fn-render_table PURPOSE="Рендеринг HTML таблицы в Word таблицу"/>
        <fn-render_list PURPOSE="Рендеринг HTML списка с вложенностью"/>
      </annotations>
    </M-RENDERER>

    <M-GRACE NAME="GraceInjector" TYPE="CORE_LOGIC" STATUS="planned">
      <purpose>Инъекция 5 GRACE XML-частей и парных закладок в .docx архив</purpose>
      <path>src/grace_injector.py</path>
      <depends>M-CONFIG, M-DISCOVERY, M-TYPES</depends>
      <verification-ref>V-M-GRACE</verification-ref>
      <annotations>
        <fn-make_grace_manifest PURPOSE="Генерация grace-manifest.xml"/>
        <fn-make_grace_instructions PURPOSE="Генерация grace-instructions.xml"/>
        <fn-make_grace_graph PURPOSE="Генерация grace-graph.xml"/>
        <fn-make_grace_contracts PURPOSE="Генерация grace-contracts.xml"/>
        <fn-make_grace_verification PURPOSE="Генерация grace-verification.xml"/>
        <fn-inject_bookmark PURPOSE="Вставка пары bookmarkStart/bookmarkEnd"/>
        <fn-inject_grace_parts PURPOSE="Инъекция 5 XML-частей в .docx"/>
      </annotations>
    </M-GRACE>

    <M-VALIDATOR NAME="OutputValidator" TYPE="UTILITY" STATUS="planned">
      <purpose>Проверка целостности сгенерированного .docx: валидация XML, баланс закладок, Content_Types</purpose>
      <path>src/validator.py</path>
      <depends>M-GRACE, M-TYPES</depends>
      <verification-ref>V-M-VALIDATOR</verification-ref>
      <annotations>
        <fn-validate_grace_docx PURPOSE="Полная проверка GRACE .docx"/>
        <fn-validate_grace_xml PURPOSE="Проверить все grace-*.xml"/>
        <fn-validate_bookmarks PURPOSE="Проверить парность закладок"/>
        <fn-validate_content_types PURPOSE="Проверить регистрацию GRACE-частей"/>
      </annotations>
    </M-VALIDATOR>

    <M-DOCXBUILDER NAME="DocumentBuilder" TYPE="ENTRY_POINT" STATUS="planned">
      <purpose>Сборка полного документа через Docusaurus-first ordering: титульная страница, оглавление, главы</purpose>
      <path>src/main.py</path>
      <depends>M-CONFIG, M-PARSER, M-RENDERER, M-SIDEBAR, M-DISCOVERY, M-GRAPHSYNC, M-GRACE, M-VALIDATOR, M-TYPES</depends>
      <verification-ref>V-M-DOCXBUILDER</verification-ref>
      <annotations>
        <fn-main PURPOSE="Точка входа: sidebar → graph sync → документ → сохранение"/>
      </annotations>
    </M-DOCXBUILDER>

